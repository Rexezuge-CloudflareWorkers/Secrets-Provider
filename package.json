{
  "name": "@rexezuge/secrets-provider",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types --config wrangler.template.jsonc",
    "checks": "npm run cf-typegen && npm run prettier && npm run lint && npm run tsc",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "deploy:fast": "wrangler deploy",
    "prettier": "prettier --write '!app' .",
    "lint": "eslint --ext .ts,.tsx --fix .",
    "tsc": "tsc --noemit"
  },
  "devDependencies": {
    "eslint": "^10.6.x",
    "eslint-config-prettier": "^10.1.x",
    "eslint-plugin-prettier": "^5.5.x",
    "globals": "^17.7.x",
    "jsonc-parser": "^3.3.x",
    "prettier": "^3.9.x",
    "typescript": "^6.0.x",
    "typescript-eslint": "^8.62.x",
    "wrangler": "^4.107.x"
  },
  "dependencies": {}
}
