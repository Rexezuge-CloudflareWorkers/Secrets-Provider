{
  // "$version": 1773798856,
  // "$minimumVersion": 1773798856,
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "secrets-provider",
  "main": "src/index.ts",
  "compatibility_date": "2025-12-31",
  "compatibility_flags": [],
  "preview_urls": false,
  "workers_dev": true,
  "minify": true,
  "observability": {
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "invocation_logs": true,
      "persist": true,
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
  "routes": [],
  "placement": {
    "mode": "off",
  },
  "secrets_store_secrets": [
    {
      "binding": "BEARER_TOKEN_SECRET",
      "store_id": "00000000000000000000000000000000",
      "secret_name": "secrets-provider-bearer-token",
    },
    {
      "binding": "TAILSCALE_AUTH_KEY_SECRET",
      "store_id": "00000000000000000000000000000000",
      "secret_name": "secrets-provider-tailscale-auth-key",
    },
    {
      "binding": "CLOUDFLARE_TUNNEL_TOKEN_SECRET",
      "store_id": "00000000000000000000000000000000",
      "secret_name": "secrets-provider-cloudflare-tunnel-token",
    },
  ],
}